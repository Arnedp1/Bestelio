# PostgreSQL (docker-compose default)
DATABASE_URL="postgresql://honger:honger@localhost:5433/honger?schema=public"

# Auth — generate: openssl rand -base64 32
AUTH_SECRET="change-me-in-production"
NEXTAUTH_SECRET="change-me-in-production"
# Moet overeenkomen met je browser-URL (gebruik localhost, niet 127.0.0.1)
NEXTAUTH_URL="http://localhost:3000"

# Demo tenant hostname + admin (seed)
DEFAULT_TENANT_HOST="localhost"
SEED_ADMIN_EMAIL="admin@demo.local"
SEED_ADMIN_PASSWORD="demo-admin-change-me"

# --- Betalingen ---
# Echte Mollie: plak test_ key in Admin → Instellingen (aanbevolen) of hier:
# MOLLIE_API_KEY="test_…"
PAYMENT_SIMULATE="false"

# Demo zonder Mollie (geen betaalscherm):
# PAYMENT_SIMULATE="true"
