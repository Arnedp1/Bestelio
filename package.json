{
  "name": "honger-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:import-modifiers": "tsx scripts/import-category-modifiers.ts",
    "db:setup": "node scripts/setup-db.mjs",
    "db:studio": "prisma studio",
    "setup": "docker compose up db -d && node scripts/setup-db.mjs",
    "start:local": "powershell -ExecutionPolicy Bypass -File scripts/start-local.ps1",
    "verify:mollie": "node scripts/verify-mollie-key.mjs",
    "qz:setup-cert": "node scripts/setup-qz-cert.mjs",
    "print:agent": "cd scripts/print-agent && npm install && npm start",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.2",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.29",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "postcss": "^8.5.15",
    "prisma": "^6.19.3",
    "selfsigned": "^5.5.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.3",
    "typescript": "^5",
    "vitest": "^3.2.4"
  },
  "overrides": {
    "next": {
      "postcss": "$postcss"
    }
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
